  "dependencies": {
    "@remotion/captions": "^4.0.486",
    "@remotion/cli": "4.0.486",
    "@remotion/install-whisper-cpp": "^4.0.486",
    "@remotion/layout-utils": "^4.0.486",
    "@remotion/media": "4.0.486",
    "@remotion/tailwind-v4": "4.0.486",
    "lucide-react": "^0.468.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.486",
    "tailwindcss": "4.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.486",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
