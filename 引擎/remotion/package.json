  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc",
    "video:studio": "remotion studio",
    "whisper:install": "node scripts/transcribe-local.mjs --install-only",
